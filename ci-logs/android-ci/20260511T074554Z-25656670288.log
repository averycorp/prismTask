2026-05-11T07:42:27.1786467Z 35-->/home/runner/work/prismTask/prismTask/app/src/main/AndroidManifest.xml:30:22-71
2026-05-11T07:42:27.1787605Z 36    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
