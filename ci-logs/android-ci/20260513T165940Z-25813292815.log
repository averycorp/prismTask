2026-05-13T16:57:34.2324138Z 35-->/home/runner/work/prismTask/prismTask/app/src/main/AndroidManifest.xml:30:22-71
2026-05-13T16:57:34.2334158Z 36    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
