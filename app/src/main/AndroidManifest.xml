<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!--
        Required for reminders to pop as full-screen notifications over the
        lock screen when the user enables "Full-Screen Notifications" in
        Settings → Notifications. Android 14+ restricts this to apps whose
        core function is alarms/calendar/communication; for other apps the
        system downgrades it to a heads-up notification, which is fine —
        we only request it when the toggle is on.
    -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!--
        Exact alarm permissions. We request both so reminders fire reliably
        across Android versions:
          - SCHEDULE_EXACT_ALARM: required on Android 12 (API 31-32); the
            user must toggle it on via Settings. We prompt for this in
            MainActivity when canScheduleExactAlarms() returns false.
          - USE_EXACT_ALARM: auto-granted on Android 13+ (API 33+) for
            calendar/reminder/timer-style apps, so no prompt is needed.
        Without USE_EXACT_ALARM the app was silently falling back to
        inexact alarms on Android 13+, which Samsung (and other OEMs)
        aggressively delay or drop under Doze/App Standby.
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!--
        Used on Samsung and other OEM devices that aggressively optimize
        battery usage. MainActivity shows a one-time dialog that opens
        the system "ignore battery optimizations" screen so scheduled
        reminders are not deferred indefinitely.
    -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!--
        Foreground service used to keep the Pomodoro countdown alive when
        the app is backgrounded. Without this, a viewModelScope coroutine
        is cancelled as soon as the user switches apps and the completion
        notification is never shown. The timer is declared as a
        mediaPlayback foreground service because Samsung One UI suppresses
        FOREGROUND_SERVICE_SPECIAL_USE notifications, preventing the
        ongoing countdown notification from appearing on those devices.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:name=".PrismTaskApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.PrismTask"
        tools:targetApi="35">

        <!-- Disable the default WorkManagerInitializer so that
             PrismTaskApplication (Configuration.Provider) can supply its
             own HiltWorkerFactory. Without this removal, certain devices
             race between the default initializer and Hilt injection,
             causing startup crashes. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PrismTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- v1.4.0 V9: accept shared text from other apps (Claude,
                 ChatGPT, email, messaging) so users can extract tasks
                 straight from a conversation via the Android share
                 sheet. MainActivity forwards the EXTRA_TEXT to the
                 PasteConversation screen. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <service
            android:name=".notifications.PomodoroTimerService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="false" />

        <receiver
            android:name=".notifications.ReminderBroadcastReceiver"
            android:exported="false" />

        <receiver
            android:name=".notifications.EscalationBroadcastReceiver"
            android:exported="false" />

        <receiver
            android:name=".notifications.CompleteTaskReceiver"
            android:exported="false" />

        <receiver
            android:name=".notifications.MedicationReminderReceiver"
            android:exported="false" />

        <receiver
            android:name=".notifications.HabitFollowUpReceiver"
            android:exported="false" />

        <receiver
            android:name=".notifications.HabitFollowUpDismissReceiver"
            android:exported="false" />

        <receiver
            android:name=".notifications.LogMedicationReceiver"
            android:exported="false" />

        <receiver
            android:name=".notifications.MedStepReminderReceiver"
            android:exported="false" />

        <receiver
            android:name=".notifications.TimerBuzzerDismissReceiver"
            android:exported="false" />

        <receiver
            android:name=".notifications.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".widget.TodayWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/today_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.HabitStreakWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/habit_streak_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.ProjectWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/project_widget_info" />
        </receiver>

        <activity
            android:name=".widget.ProjectWidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.PrismTask">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!--
            Override Google Play Billing's ProxyBillingActivity so the system
            cannot restore it from Recents or after process death with a
            stale Intent. The library's onCreate reads the PendingIntent
            extra without null-checking; if Android recreates the activity
            and the extra is missing, it NPEs on
            PendingIntent.getIntentSender(). noHistory + excludeFromRecents
            ensures the activity is finished as soon as it leaves the
            foreground and is never re-entered with a missing extra. See
            crash report tagged "ProxyBillingActivity NPE" for context.
        -->
        <activity
            android:name="com.android.billingclient.api.ProxyBillingActivity"
            android:exported="false"
            android:noHistory="true"
            android:excludeFromRecents="true"
            tools:node="merge"
            tools:replace="android:noHistory,android:excludeFromRecents" />

        <receiver
            android:name=".widget.QuickAddWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/quick_add_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.ProductivityWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/productivity_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.UpcomingWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/upcoming_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.TimerWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/timer_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.CalendarWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/calendar_widget_info" />
        </receiver>

        <!-- Eisenhower matrix widget (proposed in Widget Mockups, v1.7+) -->
        <receiver
            android:name=".widget.EisenhowerWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/eisenhower_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.StreakCalendarWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/streak_calendar_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.FocusWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/focus_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.MedicationWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/medication_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.StatsSparklineWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/stats_sparkline_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.InboxWidgetReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/inbox_widget_info" />
        </receiver>
    </application>
</manifest>
